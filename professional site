<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Portfolio</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: #e2e8f0;
      line-height: 1.6;
    }

    header {
      background: #111827;
      padding: 20px;
      text-align: center;
      position: sticky;
      top: 0;
    }

    header h1 {
      color: #38bdf8;
    }

    nav a {
      color: #e2e8f0;
      margin: 0 10px;
      text-decoration: none;
    }

    nav a:hover {
      color: #38bdf8;
    }

    .hero {
      padding: 80px 20px;
      text-align: center;
    }

    .hero h2 {
      font-size: 40px;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 18px;
      color: #94a3b8;
    }

    .section {
      padding: 60px 20px;
      max-width: 900px;
      margin: auto;
    }

    .section h3 {
      margin-bottom: 20px;
      color: #38bdf8;
      font-size: 28px;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      margin-bottom: 15px;
      border-radius: 10px;
    }

    .skills span {
      display: inline-block;
      background: #334155;
      padding: 8px 12px;
      margin: 5px;
      border-radius: 20px;
      font-size: 14px;
    }

    footer {
      text-align: center;
      padding: 20px;
      background: #111827;
      margin-top: 40px;
      font-size: 14px;
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <header>
    <h1>Your Name</h1>
    <nav>
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#skills">Skills</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero">
    <h2>Hi, I'm a Developer 👨‍💻</h2>
    <p>I build simple, clean and useful web applications.</p>
  </section>

  <section id="about" class="section">
    <h3>About Me</h3>
    <div class="card">
      I am an IT student passionate about web development, programming, and building real-world projects. I enjoy learning new technologies and improving my coding skills.
    </div>
  </section>

  <section id="projects" class="section">
    <h3>Projects</h3>

    <div class="card">
      <h4>Portfolio Website</h4>
      <p>A personal website hosted on GitHub Pages.</p>
    </div>

    <div class="card">
      <h4>Python Projects</h4>
      <p>Small scripts and programs built while learning Python.</p>
    </div>
  </section>

  <section id="skills" class="section">
    <h3>Skills</h3>
    <div class="skills">
      <span>HTML</span>
      <span>CSS</span>
      <span>Python</span>
      <span>GitHub</span>
      <span>Basic JavaScript</span>
    </div>
  </section>

  <section id="contact" class="section">
    <h3>Contact</h3>
    <div class="card">
      Email: yourname@email.com<br>
      GitHub: https://github.com/yourusername
    </div>
  </section>

  <footer>
    © 2026 Your Name. All rights reserved.
  </footer>

</body>
</html>
